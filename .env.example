# ===== OKX SA API (from web3.okx.com — API key / secret / passphrase) =====
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ===== Seller (Argus treasury — receives all payments) =====
PAY_TO=0x...
# Signs MPP session vouchers; MUST be the private key of PAY_TO
MPP_MERCHANT_PRIVATE_KEY=0x...

# ===== MPP =====
# Any high-entropy string; signs 402 challenges
MPP_SECRET_KEY=
# OKX default escrow on X Layer (SDK default — do not change unless OKX rotates it)
MPP_ESCROW=0x5E550002e64FaF79B41D89fE8439eEb1be66CE3b

# ===== Revenue split =====
# Data-partner wallet receiving 10% of every MPP charge
SPLIT_PARTNER=0x...

# ===== Explain engine =====
GROQ_API_KEY=
XLAYER_RPC=https://rpc.xlayer.tech
SOLANA_RPC=https://api.mainnet-beta.solana.com

# ===== Buyer agents (patron fleet — REAL USD₮0 on X Layer mainnet) =====
BUYER_PRIVATE_KEY=0x...

# ===== Server =====
PORT=4000
